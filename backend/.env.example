PORT=4000

# ── Base de datos ──────────────────────────────────────────────────────────────
# Railway: usa las variables que Railway auto-genera al agregar el plugin MySQL
# (copia los valores desde el tab "Variables" del plugin en Railway)
DB_HOST=containers-us-west-xxx.railway.app
DB_PORT=6543
DB_NAME=railway
DB_USER=root
DB_PASS=tu_password_aqui
# Solo para XAMPP local. En Railway dejar en blanco o eliminar esta línea:
# DB_SOCKET=/Applications/XAMPP/xamppfiles/var/mysql/mysql.sock

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_STRONG_RANDOM_64_BYTE_HEX
JWT_EXPIRES_IN=8h

# ── URLs de los frontends (actualiza con tus dominios reales de Vercel) ────────
FRONTEND_URL=https://tu-app.vercel.app
ADMIN_URL=https://tu-admin.vercel.app

UPLOAD_DIR=./uploads

# SMTP (opcional — si no se configura, el enlace se loguea en consola en modo dev)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@tudominio.com
SMTP_PASS=tu_password_smtp
SMTP_FROM="ModulaERP <noreply@tudominio.com>"
