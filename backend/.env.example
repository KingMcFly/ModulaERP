PORT=4000

# ── Base de datos ──────────────────────────────────────────────────────────────
# Opción 1: Connection string (Supabase / Aiven / Railway PostgreSQL)
# Supabase: Settings → Database → Connection string (URI)
# Aiven: Service overview → Connection information → Service URI
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Opción 2: Variables individuales (si no usas DATABASE_URL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=modulaerp_db
# DB_USER=postgres
# DB_PASS=tu_password_aqui

# ── Auth ───────────────────────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_STRONG_RANDOM_64_BYTE_HEX
JWT_EXPIRES_IN=8h

# ── URLs de los frontends (actualiza con tus dominios reales de Vercel) ────────
FRONTEND_URL=https://tu-app.vercel.app
ADMIN_URL=https://tu-admin.vercel.app

UPLOAD_DIR=./uploads

# SMTP (opcional — si no se configura, el enlace se loguea en consola en modo dev)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@tudominio.com
SMTP_PASS=tu_password_smtp
SMTP_FROM="ModulaERP <noreply@tudominio.com>"
