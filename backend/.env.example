PORT=4000

# ── Base de datos ──────────────────────────────────────────────────────────────
# Opción 1: Connection string (Supabase / Aiven / Railway PostgreSQL)
# Supabase: Settings → Database → Connection string (URI)
# Aiven: Service overview → Connection information → Service URI
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Opción 2: Variables individuales (si no usas DATABASE_URL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=modulaerp_db
# DB_USER=postgres
# DB_PASS=tu_password_aqui

# ── Auth ───────────────────────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_STRONG_RANDOM_64_BYTE_HEX
JWT_EXPIRES_IN=8h

# ── URLs de los frontends (actualiza con tus dominios reales de Vercel) ────────
FRONTEND_URL=https://tu-app.vercel.app
ADMIN_URL=https://tu-admin.vercel.app

UPLOAD_DIR=./uploads

# SMTP — Zoho Mail (puerto 465 SSL)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@fbcore.cloud
SMTP_PASS=tu_app_password_zoho
SMTP_FROM="FB Core <noreply@fbcore.cloud>"

# ── Seguridad adicional ────────────────────────────────────────────────────────
# Token secreto para endpoints de cron (Vercel Cron)
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=CHANGE_ME_RANDOM_32_BYTE_HEX

# WhatsApp para notificaciones de trial (opcional)
COMPANY_WHATSAPP_NUMBER=+56912345678

# ── OpenStatus.dev — página de estado pública ─────────────────────────────────
# Genera tu token en: openstatus.dev → Settings → API Tokens
OPENSTATUS_API_KEY=
