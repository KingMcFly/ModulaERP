PORT=4000
DB_HOST=localhost
DB_PORT=3306
DB_NAME=modulaerp_db
DB_USER=root
DB_PASS=your_strong_db_password_here
DB_SOCKET=

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_STRONG_RANDOM_64_BYTE_HEX
JWT_EXPIRES_IN=4h

UPLOAD_DIR=./uploads
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# SMTP (opcional — si no se configura, el enlace se loguea en consola en modo dev)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@tudominio.com
SMTP_PASS=tu_password_smtp
SMTP_FROM="ModulaERP <noreply@tudominio.com>"
