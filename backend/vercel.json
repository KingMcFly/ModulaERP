{
  "version": 2,
  "builds": [
    {
      "src": "src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-alerts",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/ticket-sla",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/ticket-recurring",
      "schedule": "0 6 * * *"
    }
  ]
}
